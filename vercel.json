{
	"rewrites": [
	  {
		"source": "/api/:path*",
		"destination": "http://157.245.142.58:3005/api/:path*"
	  },
	  {
		"source": "/(.*)",
		"destination": "/index.html"
	  }
	],
	"headers": [
	  {
		"source": "/api/:path*",
		"headers": [
		  {
			"key": "Access-Control-Allow-Origin",
			"value": "*"
		  },
		  {
			"key": "Access-Control-Allow-Methods",
			"value": "GET, POST, PUT, DELETE, PATCH, OPTIONS"
		  },
		  {
			"key": "Access-Control-Allow-Headers",
			"value": "Content-Type, Authorization, user-id, X-Requested-With"
		  }
		]
	  }
	]
}